{
  "name": "car-rental",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@openzeppelin/contracts": "^4.9.3",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "framer-motion": "^12.38.0",
    "picomatch": "^2.3.1",
    "react": "^18.2.0",
    "react-datepicker": "^4.10.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.8.0",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "start:backend": "node backend/server.js",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:contracts": "npx hardhat test",
    "eject": "react-scripts eject",
    "lint": "eslint \"src/**/*.{js,jsx}\" \"backend/**/*.js\" \"scripts/**/*.js\" \"test/**/*.js\" \"hardhat.config.js\"",
    "lint:fix": "eslint \"src/**/*.{js,jsx}\" \"backend/**/*.js\" \"scripts/**/*.js\" \"test/**/*.js\" \"hardhat.config.js\" --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "quality": "npm run lint && npm run test:contracts && npm run build"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest",
      "prettier"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@nomiclabs/hardhat-ethers": "^2.2.3",
    "@nomiclabs/hardhat-waffle": "^2.0.6",
    "chai": "^4.3.8",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "ethereum-waffle": "^4.0.10",
    "ethers": "^5.7.2",
    "hardhat": "^2.17.2",
    "prettier": "^3.6.2"
  }
}
